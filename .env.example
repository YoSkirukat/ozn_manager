FLASK_APP=wsgi:app
# Планировщик регламентных заданий (встроенный, без cron). 0 — отключить.
SCHEDULER_ENABLED=1
# Один планировщик на БД (обязательно при gunicorn -w > 1). 0 — только для отладки.
SCHEDULER_FILE_LOCK=1
SCHEDULER_TIMEZONE=Europe/Moscow
# Часовой пояс для отображения дат в интерфейсе
APP_TIMEZONE=Europe/Moscow
# Как часто планировщик перечитывает включённые задания из БД (секунды)
SCHEDULER_SYNC_SECONDS=30
# 0 — без двойного процесса Flask (планировщик надёжнее при разработке)
FLASK_USE_RELOADER=0
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Относительный путь ок — в config.py он станет абсолютным
DATABASE_URL=sqlite:///instance/ozn_manager.db

# Ozon Seller API (https://seller.ozon.ru/app/settings/api-keys)
OZON_CLIENT_ID=
OZON_API_KEY=
